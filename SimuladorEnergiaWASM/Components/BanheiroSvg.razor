@using SimuladorEnergiaWASM.Models

@code {

    [Parameter]
    public EventCallback<ItemCenario> Clique { get; set; }

    private async Task TratarClique(string nomeAparelho, int potencia, double horas)
    {
        var aparelho = new ItemCenario
        {
            Nome = nomeAparelho,
            Consumo = potencia,
            HorasUso = horas
        };
        // Dispara o evento para o pai ouvir
        await Clique.InvokeAsync(aparelho);
    }
}

