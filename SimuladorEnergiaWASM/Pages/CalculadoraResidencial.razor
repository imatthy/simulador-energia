@using SimuladorEnergiaWASM.Components
@using SimuladorEnergiaWASM.Models
@using System.Globalization

<div class="conteudo">

	<div class="layout-principal">
			<div class="d-flex gap-2 overflow-auto pb-2">

				<button class='btn @(ComodoAtual == "Cozinha" ? "btn-primary shadow-sm" : "btn-outline-primary")'
						@onclick='() => MudarComodo("Cozinha")'>
					<i class="bi bi-cup-hot me-2"></i> Cozinha
				</button>

				<button class='btn @(ComodoAtual == "Banheiro" ? "btn-primary shadow-sm" : "btn-outline-primary")'
						@onclick='() => MudarComodo("Banheiro")'>
					<i class="bi bi-droplet me-2"></i> Banheiro
				</button>

				<button class='btn @(ComodoAtual == "Sala" ? "btn-primary shadow-sm" : "btn-outline-primary")'
						@onclick='() => MudarComodo("Sala")'>
					<i class="bi bi-tv me-2"></i> Sala de Estar
				</button>

				<button class='btn @(ComodoAtual == "Quarto" ? "btn-primary shadow-sm" : "btn-outline-primary")'
						@onclick='() => MudarComodo("Quarto")'>
					<i class="bi bi-moon-stars me-2"></i> Quarto
				</button>
				<button class='btn @(ComodoAtual == "Lavanderia" ? "btn-primary shadow-sm" : "btn-outline-primary")'
						@onclick='() => MudarComodo("Lavanderia")'>
					<i class="bi bi-droplet-fill me-2"></i> Lavanderia
				</button>

			</div>
		<div class="desenho_svg">
			@switch (ComodoAtual)
			{
				case "Cozinha":
					<CozinhaSvg Clique="AbrirMenu" />
					break;

				case "Banheiro":
					<BanheiroSvg Clique="AbrirMenu" />
					break;

				case "Sala":
					<SalaSvg Clique="AbrirMenu" />
					break;

				case "Quarto":
					<QuartoSvg Clique="AbrirMenu" />
					break;

				case "Lavanderia":
					<LavanderiaSvg Clique="AbrirMenu" />
					break;

				default:
					<div class="text-muted mt-5">
						<i class="bi bi-exclamation-circle fs-1 mb-3 d-block"></i>
						<p>Cômodo não encontrado ou em construção.</p>
					</div>
					break;
			}
		</div>

		<div class="text-center mt-3">
			<button type="button" class="btn btn-outline-primary" @onclick="() => MenuConsumoAberto = true">
				Clique aqui para adicionar o seu consumo de energia mensal diretamente.
			</button>
		</div>

		@if (MenuAberto)
		{
			<div class="modal fade show" tabindex="-1" role="dialog" style="display:block; background-color: rgba(0,0,0,0.5)" ;>
				<div class="modal-dialog modal-dialog-centered" role="document">
					<div class="modal-content">
						<div class="modal-header">
							<h5 class="modal-title fw-bold text-primary">
								<span class="bi bi-plug-fill me-2"></span>
								@(string.IsNullOrWhiteSpace(ItemTemp.Nome) ? "Novo Aparelho" : $"Adicionar {ItemTemp.Nome}")
							</h5>
							<button type="button" class="btn-close" @onclick="() => MenuAberto = false" aria-label="Close"></button>
						</div>
						<EditForm Model="@ItemTemp" OnValidSubmit="SalvarItem">
							<DataAnnotationsValidator />
							<div class="modal-body p-4">
								<p class="text-muted small mb-4">
									Preencha as informações abaixo para calcularmos o consumo deste aparelho.
								</p>

								<div class="mb-3">
									<label class="form-label fw-bold">Nome do Item:</label>
									<InputText @bind-Value="ItemTemp.Nome"
												class="form-control"
												placeholder="Ex: Geladeira, Ar condicionado...">
									</InputText>
								</div>

								<div class="mb-3">
									<label class="form-label fw-bold">Potência do item:</label>
									<div class="input-group">
										<InputNumber @bind-Value="ItemTemp.Consumo"
														min="1"
														max="50000"
														step="1"
														class="form-control">
										</InputNumber>
										<span class="input-group-text">W</span>
									</div>
								</div>

								<div class="mb-4">
									<label class="form-label fw-bold">Tempo de Uso</label>
									<div class="input-group">
										<InputNumber @bind-Value="ItemTemp.HorasUso"
														min="0.01"
														max="24"
														class="form-control">
										</InputNumber>
										<span class="input-group-text bg-light text-muted">h/dia</span>
									</div>
								</div>

							</div>
							<div class="modal-footer">
								<button type="button" class="btn btn-outline-danger" @onclick="() => MenuAberto = false">Cancelar</button>
								<button type="submit" class="btn btn-outline-primary px-4"><span class="bi bi-check2-circle me-1"></span>Salvar</button>
							</div>

						</EditForm>
					</div>
				</div>
			</div>
		}

		@if (MenuConsumoAberto)
		{
			<div class="modal fade show" tabindex="-1" role="dialog" style="display:block; background-color: rgba(0,0,0,0.5);">
				<div class="modal-dialog modal-dialog-centered">
					<div class="modal-content">
						<div class="modal-header">
							<h5 class="modal-title fw-bold text-primary">
								<span class="bi bi-plug-fill me-2"></span>
								Insira seu consumo.
							</h5>
							<button type="button" class="btn-close" @onclick="() => MenuConsumoAberto = false" aria-label="Close"></button>
						</div>

						<div class="modal-body form-label fw-bold">
							<label>Consumo:</label>
							<div class="input-group">
								<InputNumber @bind-Value="ConsumoTemp"
												class="form-control"
												min="0"
												max="10000"
												step="1">
								</InputNumber>
								<span class="input-group-text">kWh/mês</span>
							</div>
						</div>

						<div class="modal-footer">
							<button type="button" class="btn btn-outline-danger" @onclick="() => MenuConsumoAberto = false">Cancelar</button>
							<button type="submit" class="btn btn-outline-primary" @onclick="() => SalvarConsumo()"><span class="bi bi-check2-circle me-1"></span>Salvar</button>
						</div>
					</div>
				</div>
			</div>
		}

		@if (MenuPainelAberto)
		{
			<div class="modal fade show" tabindex="-1" style="display:block; background-color: rgba(0,0,0,0.5);">
				<div class="modal-dialog modal-dialog-centered">
					<div class="modal-content">
						<div class="modal-header">
							<h5 class="modal-title fw-bold text-primary">
								<span class="bi bi-plug-fill me-2"></span>
								Configurações do Painel Solar
							</h5>
							<button type="button" class="btn-close" @onclick="FecharModal"></button>
						</div>

						@if (ConfigPainel)
						{
							<EditForm Model="@PainelTemp" OnValidSubmit="SalvarPainel">
								<DataAnnotationsValidator />

								<div class="modal-body p-4">
									<p class="text-muted small mb-4">
										Modifique as variáveis técnicas referentes ao painel solar!
									</p>

									<ValidationSummary class="text-danger mb-3" />

									<div class="mb-3">
										<label class="form-label fw-bold">Potência do Painel Solar:</label>
										<div class="input-group">
											<InputNumber @bind-Value="PainelTemp.Potencia" class="form-control" />
											<span class="input-group-text">W</span>
										</div>
									</div>

									<div class="mb-3">
										<label class="form-label fw-bold">Eficiência do Sistema (Inversor/Perdas):</label>
										<div class="input-group">
											<InputNumber @bind-Value="PainelTemp.Eficiencia" class="form-control" />
											<span class="input-group-text">%</span>
										</div>
									</div>

									<div class="mb-3">
										<label class="form-label fw-bold">Fator de simultaneidade:</label>
										<div class="input-group">
											<InputNumber @bind-Value="PainelTemp.FatorSimA" step="1" class="form-control" />
											<span class="input-group-text">%</span>
										</div>
									</div>

									<div class="mb-3">
										<label class="form-label fw-bold">Temperatura Ambiente Média:</label>
										<div class="input-group">
											<InputNumber @bind-Value="PainelTemp.TempAmb" class="form-control" />
											<span class="input-group-text">°C</span>
										</div>
									</div>
								</div>
								<div class="mb-3 text-center border-top">
									<button type="button" class="btn btn-link text-decoration-none fw-bold" @onclick="AlternarOpcoesAvancadas">
										<i class="bi @(mostrarAvancadas ? "bi-chevron-up" : "bi-chevron-down") me-1"></i>
										@(mostrarAvancadas ? "Ocultar configurações avançadas" : "Mostrar configurações avançadas")
									</button>
								</div>
								@if (mostrarAvancadas)
								{
									<div class="p-3 bg-light border rounded mb-3">

										<div class="mb-3">
											<label class="form-label fw-bold">Temperatura Nominal (NOCT):</label>
											<div class="input-group">
												<InputNumber @bind-Value="PainelTemp.Noct" min="0" max="100" class="form-control" />
												<span class="input-group-text">°C</span>
											</div>
										</div>

										<div class="mb-3">
											<label class="form-label fw-bold">Eficiência do Painel Solar:</label>
											<div class="input-group">
												<InputNumber @bind-Value="PainelTemp.EficNominal" class="form-control" />
												<span class="input-group-text">%</span>
											</div>
										</div>

										<div class="mb-3">
											<label class="form-label fw-bold">Coeficiente de perda por calor (Pmpp):</label>
											<div class="input-group">
												<InputNumber @bind-Value="PainelTemp.Pmpp" step="0.01" class="form-control" />
												<span class="input-group-text">%</span>
											</div>
										</div>

										<div class="mb-3">
											<label class="form-label fw-bold">Horas de Sol Pleno (HSP):</label>
											<div class="input-group">
												<InputNumber @bind-Value="PainelTemp.HorasSol" class="form-control" />
												<span class="input-group-text">h</span>
											</div>
										</div>
									</div>
								}
								<div class="modal-footer">
									<button type="button" class="btn btn-outline-danger" @onclick="FecharModal">Cancelar</button>
									<button type="submit" class="btn btn-outline-primary">Salvar</button>
								</div>
							</EditForm>
						}

						@if (ConfigPainelFinanceiro)
						{
							<EditForm Model="@PainelTemp" OnValidSubmit="SalvarPainel">
								<DataAnnotationsValidator />

								<div class="modal-body p-4">
									<p class="text-muted small mb-4">
										Modifique as variáveis financeiras!
									</p>

									<ValidationSummary class="text-danger mb-3" />

									<div class="mb-3">
										<label class="form-label fw-bold">Custo do Painel Solar:</label>
										<div class="input-group">
											<span class="input-group-text">R$</span>
											<InputNumber @bind-Value="PainelTemp.Custo" class="form-control" />
										</div>
									</div>

									<div class="mb-3">
										<label class="form-label fw-bold">Tarifa de Energia:</label>
										<div class="input-group">
											<span class="input-group-text">R$</span>
											<InputNumber @bind-Value="PainelTemp.TarifaEnergia" step="0.01" class="form-control" />
										</div>
									</div>
									<div class="mb-3">
										<label class="form-label fw-bold">Tarifa do Uso de Distribuição:</label>
										<div class="input-group">
											<span class="input-group-text">R$</span>
											<InputNumber @bind-Value="PainelTemp.TUSD" step="0.01" class="form-control" />
										</div>
									</div>

									<div class="mb-3">
										<label class="form-label fw-bold d-block">Padrão de Ligação (Taxa Mínima):</label>
										<div class="btn-group w-100 shadow-sm" role="group" aria-label="Tipo de ligação">
											<button type="button"
													class="btn @(PainelTemp.TaxaMinima == 30 ? "btn-primary" : "btn-outline-primary")"
													@onclick="() => { PainelTemp.TaxaMinima = 30; StateHasChanged(); }">
													Monofásico <small class="d-block">(30 kWh)</small>
											</button>

											<button type="button"
													class="btn @(PainelTemp.TaxaMinima == 50 ? "btn-primary" : "btn-outline-primary")"
													@onclick="() => { PainelTemp.TaxaMinima = 50; StateHasChanged(); }">
												Bifásico <small class="d-block">(50 kWh)</small>
											</button>

											<button type="button"
													class="btn @(PainelTemp.TaxaMinima == 100 ? "btn-primary" : "btn-outline-primary")"
													@onclick="() => { PainelTemp.TaxaMinima = 100; StateHasChanged(); }">
												Trifásico <small class="d-block">(100 kWh)</small>
											</button>
										</div>
										<div class="form-text mt-2">
											<i class="bi bi-info-circle"></i> O sistema considerará apenas o consumo excedente a esse valor para o cálculo das placas.
										</div>
									</div>
								</div>
								<div class="modal-footer">
									<button type="button" class="btn btn-outline-danger" @onclick="FecharModal">Cancelar</button>
									<button type="submit" class="btn btn-outline-primary">Salvar</button>
								</div>
							</EditForm>
						}
					</div>
				</div>
			</div>
		}

	</div>


	<div class="alert alert-light border shadow-sm area-informacoes">
		<h5 class="text-danger d-flex align-items-center">
			<span class="me-2" style="font-size: 1.5em;">&#33;</span>
			<span>Atenção! Resultados estimados.</span>
			<span class="ms-auto">
				<button class="btn btn-outline-danger" @onclick="() => { AbrirMenuPainel(); ConfigPainel = true; }">Editar variáveis.</button>
			</span>

			@if (ItensCenario.Any() || ConsumoMes > 0)
			{
				<span class="ms-auto">
					<button class="btn btn-outline-danger" @onclick="() => ResetarCenario()">Resetar dados</button>
				</span>
			}
		</h5>
		<hr class="my-2" />

		@if (TemDados)
		{
			<div class="row text-center mb-4">
				<div class="col-md-4">
					<div class="card bg-light">
						<div class="card-body">
							<h6 class="card-title text-muted">Consumo Mensal</h6>
							<h4>@TotalKwhMensal.ToString("N2") kWh</h4>
							<small class="d-block">@TotalKwhDiario.ToString("N2") kWh/dia</small>
							<small class="d-block" style="color: darkcyan">Taxa Mínima: @PainelDados.TaxaMinima.ToString("N2") kWh
								<a href="javascript:void(0)" class="text-success text-decoration-underline small d-inline-block" @onclick="AbrirModalExplicacaoTaxa">
								<i class="bi bi-question-circle"></i>
								</a>
							</small>
						</div>
					</div>
				</div>
				<div class="col-md-4">
					<div class="card bg-light">
						<div class="card-body">
							<h6 class="card-title text-muted">Custo Estimado</h6>
							<h4>@TotalCustoMensal.ToString("C2", new CultureInfo("pt-BR"))/mês</h4>
							<small class="d-block">@TotalCustoDiario.ToString("C2", new CultureInfo("pt-BR"))/dia</small>
							<small class="d-block" style="color: darkcyan">Taxa mínima: R$ @(PainelDados.TaxaMinima * (PainelDados.TUSD + PainelDados.TarifaEnergia))</small>
						</div>
					</div>
				</div>
				<div class="col-md-4">
					<div class="card border-primary text-primary">
						<div class="card-body">
							<h6 class="card-title">Placas Necessárias</h6>
							<h3>@PlacasCalculadas un.</h3>
							<small>Painéis de @PainelDados.Potencia W</small>
						</div>
					</div>
				</div>
			</div>


			@if (ItensCenario.Any() && ConsumoMes == 0)
			{
				<h5 class="mt-4">Detalhamento dos Aparelhos:</h5>
				<div class="table-responsive">
					<table class="table table-sm table-hover table-striped">
						<thead class="table-dark">
							<tr>
								<th>Item</th>
								<th>Potência</th>
								<th>Uso/Dia</th>
								<th>Consumo (Mês)</th>
								<th>Custo (Mês)</th>
								<th></th>
							</tr>
						</thead>
						<tbody>
							@foreach (var item in ItensCenario)
							{
								<tr>
									<td>@item.Nome</td>
									<td>@item.Consumo W</td>
									<td>@item.HorasUso h</td>
									<td>@item.CalculoKwh().ToString("N2") kWh</td>
									<td>@CalculoCusto(item).ToString("C2", new CultureInfo("pt-BR"))</td>
									<td>
										<button class="btn btn-outline-danger btn-sm py-0"
												@onclick="() => RemoveItem(item)" title="Remover">
											&times;
										</button>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}

			@if(PlacasCalculadas > 0)
			{
				
				<a href="javascript:void(0)" class="text-success text-decoration-underline small mb-3 d-inline-block" @onclick="AbrirModalExplicacao">
					<h6><i class="bi bi-question-circle"></i> Por que @PlacasCalculadas painéis é a quantidade ideal?</h6>
				</a>

				<h5>Tempo de Retorno do Investimento (Payback)</h5>
				@if (TotalCustoMensal > 0)
				{
					<div class="card bg-success bg-opacity-10 border-success border-opacity-25 p-3 rounded">

						<p class="mb-2">
							Para cobrir o seu consumo, o sistema ideal requer <strong>@PlacasCalculadas placas</strong> de @PainelDados.Potencia W.
						</p>

						<p class="mb-2">
							Com um custo estimado de <strong>@((PainelDados.Custo * PlacasCalculadas).ToString("C2", new CultureInfo("pt-br")))</strong>, o investimento se pagaria em aproximadamente:
						</p>

						<h3 class="text-success fw-bold">@FormatarTempoRetorno(TotalCustoMensal)</h3>

						<p class="mb-2" style="font-size: 0.9rem;">
							Considerando uma economia estimada de <strong>@Economia_Mensal().ToString("C2", new CultureInfo("pt-BR"))</strong> por mês.
							<a href="javascript:void(0)" class="text-success text-decoration-underline ms-1" @onclick="AbrirModalExplicacao">
								Entenda essa estimativa
							</a>
						</p>

						<button class="btn btn-outline-success btn-sm mt-1" @onclick="() => { AbrirMenuPainel(); ConfigPainelFinanceiro = true; }">
							<span class="bi bi-pencil"></span> <strong>Ajustar valores financeiros</strong>
						</button>
					</div>
				}
			}
			else
			{
				<div class="alert alert-warning border-warning border-opacity-25 shadow-sm p-4 text-center mt-3">
					<i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 2.5rem;"></i>
					<h4 class="fw-bold mt-2 text-dark">Sistema Solar Não Recomendado</h4>

					<p class="mb-0 text-muted" style="font-size: 0.95rem;">
						O seu consumo atual (<strong>@ConsumoMes kWh</strong>) é inferior ou igual à <strong>Taxa Mínima de Disponibilidade</strong> da concessionária.
					</p>

					<hr class="border-warning opacity-50 my-3">

					<p class="small text-muted mb-0 text-start">
						<strong>O que isso significa?</strong> Por lei, as concessionárias cobram um valor mínimo mensal apenas por você estar conectado à rede elétrica. Como a energia solar não pode abater essa taxa mínima, instalar painéis solares no seu caso não geraria nenhuma economia financeira na sua conta.
					</p>
				</div>
			}

		}
		else
		{
			<p class="text-muted text-center py-3">
				Adicione itens ou informe sua conta mensal para ver o resultado.
			</p>
		}
	</div>

	@if (mostrarModalExplicacao)
	{
		<div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="FecharModalExplicacao">
			<div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true">
				<div class="modal-content border-0 shadow">

					<div class="modal-header bg-success text-white border-0">
						<h5 class="modal-title fw-bold">
							<i class="bi bi-lightbulb-fill me-2"></i> O Segredo do Dimensionamento
						</h5>
						<button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="FecharModalExplicacao"></button>
					</div>

					<div class="modal-body p-4">
						<p class="text-muted" style="text-align: justify;">
							O cálculo exato seria @PlacasExatas, mas arredondamos para cima. Isso compensa dias nublados (HSP: @PainelDados.HorasSol) e perdas por eficiência (@PainelDados.Eficiencia%).
						</p>

						<p class="text-muted" style="text-align: justify;">
							Nosso simulador calculou a quantidade de placas para que não houvesse geração desperdiçada de energia e a maior economia possível (mantendo apenas as taxas obrigatórias da concessionária).
						</p>

						<div class="bg-light p-3 rounded border mt-4 mb-3">
							<h6 class="fw-bold mb-3 small text-uppercase text-secondary">A matemática:</h6>

							<div class="mb-3">
								<div class="d-flex justify-content-between small mb-1">
									<span>Teto da sua Conta de Luz</span>
									<span class="fw-bold text-dark">@(TotalCustoMensal.ToString("C2", new CultureInfo("pt-BR")))</span>
								</div>
								<div class="progress" style="height: 12px;">
									<div class="progress-bar bg-secondary" role="progressbar" style="width: 100%"></div>
								</div>
							</div>

							<div class="mb-3">
								<div class="d-flex justify-content-between small mb-1">
									<span>
										Economia Máxima <br>
										<small class="text-muted">(Se você consumisse 100% da energia fotovoltaica de dia, sem enviar para a rede da concessionária)</small>
									</span>
									<span class="fw-bold text-success">@(((decimal)Energia_fv() * Tarifa_Plena()).ToString("C2", new CultureInfo("pt-BR")))</span>
								</div>
								<div class="progress" style="height: 12px;">
									<div class="progress-bar bg-success opacity-75" role="progressbar" style="width: @(CalcularPorcentagemEconomiaTeorica())%"></div>
								</div>
							</div>

							<div class="mb-3">
								<div class="d-flex justify-content-between small mb-1">
									<span>
										Economia Real <br>
										<small class="text-muted">(Considerando as perdas do excedente enviado para a rede)</small>
									</span>
									<span class="fw-bold text-success">@(Economia_Mensal().ToString("C2", new CultureInfo("pt-BR")))</span>
								</div>
								<div class="progress" style="height: 12px;">
									<div class="progress-bar bg-success" role="progressbar" style="width: @(CalcularPorcentagemEconomia())%"></div>
								</div>
							</div>

							<div class="alert alert-light border shadow-sm py-2 px-3 mt-4 mb-0 d-flex align-items-center" style="font-size: 0.85rem;">
								<i class="bi bi-sliders text-success fs-4 me-3"></i>
								<div>
									<strong>Dica:</strong> Você pode simular o impacto do seu perfil de consumo alterando o <strong>Fator de Simultaneidade</strong> clicando no botão <em>"Editar variáveis"</em>.
								</div>
							</div>
						</div>


						<div class="alert alert-warning border-warning border-opacity-25 py-2 px-3 d-flex align-items-start mb-0" style="font-size: 0.85rem;">
							<i class="bi bi-exclamation-triangle-fill text-warning me-2 mt-1"></i>
							<span>
								<strong>E se eu adicionar mais placas?</strong> O custo de instalação aumentará, mas a sua economia continuará limitada ao valor da sua conta. A energia extra será "doada" para a rede pública, atrasando o retorno do seu investimento inicial.
							</span>
						</div>
					</div>

					<div class="modal-footer border-0">
						<button type="button" class="btn btn-success px-4" @onclick="FecharModalExplicacao">Entendi!</button>
					</div>
				</div>
			</div>
		</div>
	}
	@if (mostrarModalExplicacaoTaxa)
	{
		<div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="FecharModalExplicacaoTaxa">
			<div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true">
				<div class="modal-content border-0 shadow">

					<div class="modal-header bg-warning border-0">
						<h5 class="modal-title fw-bold text-dark">
							<i class="bi bi-building-fill-exclamation me-2"></i> O que é a Taxa Mínima?
						</h5>
						<button type="button" class="btn-close" aria-label="Close" @onclick="FecharModalExplicacaoTaxa"></button>
					</div>

					<div class="modal-body p-4">
						<h6 class="fw-bold text-dark mb-3">O "Aluguel" da Rede Elétrica</h6>

						<p class="text-muted" style="text-align: justify;">
							A Taxa Mínima (ou Custo de Disponibilidade) é um valor mínimo obrigatório pelo "aluguel" dos postes, cabos e transformadores na sua rua, garantindo que a energia chegue até você quando o sol se põe.
						</p>

						<div class="bg-light p-3 rounded border mt-4 mb-3">
							<h6 class="fw-bold mb-3 small text-uppercase text-secondary">A regra da ANEEL: Pisos de Cobrança</h6>

							<ul class="list-group list-group-flush mb-0 small">
								<li class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0">
									<span><i class="bi bi-plug text-muted me-2"></i> <strong>Rede Monofásica</strong></span>
									<span class="badge bg-secondary rounded-pill">Paga no mínimo 30 kWh</span>
								</li>
								<li class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0">
									<span><i class="bi bi-plug-fill text-muted me-2"></i> <strong>Rede Bifásica</strong></span>
									<span class="badge bg-secondary rounded-pill">Paga no mínimo 50 kWh</span>
								</li>
								<li class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-0 border-bottom-0">
									<span><i class="bi bi-lightning-charge-fill text-muted me-2"></i> <strong>Rede Trifásica</strong></span>
									<span class="badge bg-secondary rounded-pill">Paga no mínimo 100 kWh</span>
								</li>
							</ul>
							<div class="alert alert-light border shadow-sm py-2 px-3 mt-4 mb-0 d-flex align-items-center" style="font-size: 0.85rem;">
								<i class="bi bi-sliders text-success fs-4 me-3"></i>
								<div>
									<strong>Dica:</strong> Você pode alterar a <strong>taxa mínima</strong> conforme a sua residência, comércio ou empresao clicando no botão <em>"Ajustar valores financeiros"</em>.
								</div>
							</div>
						</div>


						<div class="alert alert-warning border-warning border-opacity-25 py-2 px-3 d-flex align-items-start mb-0" style="font-size: 0.85rem;">
							<i class="bi bi-info-circle-fill text-warning me-2 mt-1"></i>
							<span>
								<strong>Resumindo:</strong> Nenhuma conta de luz no Brasil chega a <strong>R$ 0,00</strong>. Mesmo gerando 100% da energia que você consome através das placas solares, a concessionária ainda cobrará esse valor mínimo de disponibilidade no final do mês.
							</span>
						</div>
					</div>

					<div class="modal-footer border-0">
						<button type="button" class="btn btn-warning px-4 fw-bold text-dark" @onclick="FecharModalExplicacaoTaxa">Entendi!</button>
					</div>
				</div>
			</div>
		</div>
	}
</div>

@code {
	private bool mostrarModalExplicacao = false;
	private bool mostrarModalExplicacaoTaxa = false;

	private void AbrirModalExplicacao() => mostrarModalExplicacao = true;
	private void FecharModalExplicacao() => mostrarModalExplicacao = false;
	private void AbrirModalExplicacaoTaxa() => mostrarModalExplicacaoTaxa = true;
	private void FecharModalExplicacaoTaxa() => mostrarModalExplicacaoTaxa = false;

	private double CalcularPorcentagemEconomia()
	{
		if (TotalCustoMensal <= 0) return 0;

		double porcentagem = (double)(Economia_Mensal() / TotalCustoMensal) * 100;
		return Math.Min(porcentagem, 100);
	}

	private double CalcularPorcentagemEconomiaTeorica()
	{
		if (TotalCustoMensal <= 0) return 0;

		decimal economiaSemFioB = (decimal)Energia_fv() * Tarifa_Plena();

		double porcentagem = (double)(economiaSemFioB / TotalCustoMensal) * 100;
		return Math.Min(porcentagem, 100);
	}

	private List<ItemCenario> ItensCenario = new();
	private ItemCenario ItemTemp = new();

	private PainelSolar PainelDados { get; set; } = new PainelSolar();
	private PainelSolar PainelTemp { get; set; } = new PainelSolar();

	bool MenuAberto = false;
	bool MenuConsumoAberto = false;
	bool MenuPainelAberto = false;

	public double ConsumoMes { get; set; } = 0;
	public double ConsumoTemp { get; set; } = 0;
	public bool ConfigPainel { get; set; } = false;
	public bool ConfigPainelFinanceiro { get; set; } = false;

	double TotalKwhMensal => ConsumoMes > 0 ? ConsumoMes : ItensCenario.Sum(i => i.CalculoKwh());
	double TotalKwhMensalAlvo => Math.Max(0, TotalKwhMensal - PainelDados.TaxaMinima);
	double TotalKwhDiario => TotalKwhMensal / 30.0;
	double TotalKwhDiarioAlvo => TotalKwhMensalAlvo / 30.0;

	decimal TotalCustoMensal => ConsumoMes > 0 ? (decimal)ConsumoMes * (PainelDados.TarifaEnergia + PainelDados.TUSD) : TotalCustoItens();
	decimal TotalCustoDiario => TotalCustoMensal / 30m;

	double NumPlacasDouble => NumPlacas(TotalKwhDiarioAlvo);
	int PlacasCalculadas => (int)Math.Ceiling(NumPlacasDouble);
	double PlacasExatas => Math.Round(NumPlacasDouble, 2);

	bool TemDados => ItensCenario.Any() || ConsumoMes > 0; 

	private bool mostrarAvancadas = false;

	private string ComodoAtual { get; set; } = "Cozinha";

	private void MudarComodo(string novoComodo) => ComodoAtual = novoComodo;

	private void AlternarOpcoesAvancadas()
	{
		mostrarAvancadas = !mostrarAvancadas;
	}

	void AbrirMenu(ItemCenario aparelho)
	{
		ItemTemp = new ItemCenario { 
			Nome = aparelho.Nome,
			Consumo = aparelho.Consumo,
			HorasUso = aparelho.HorasUso

		};
		MenuAberto = true;
	}

	void AbrirMenuConsumo()
	{
		ConsumoTemp = ConsumoMes;
		MenuConsumoAberto = true;
	}

	void AbrirMenuPainel()
	{
		PainelTemp = new PainelSolar
		{
			Id = PainelDados.Id,
			Potencia = PainelDados.Potencia,
			Eficiencia = PainelDados.Eficiencia,
			Noct = PainelDados.Noct,
			EficNominal = PainelDados.EficNominal,
			HorasSol = PainelDados.HorasSol,
			TempAmb = PainelDados.TempAmb,
			Pmpp = PainelDados.Pmpp,
			FatorSimA = PainelDados.FatorSimA,
			Custo = PainelDados.Custo,
			TarifaEnergia = PainelDados.TarifaEnergia,
			TUSD = PainelDados.TUSD,
			TaxaMinima = PainelDados.TaxaMinima
		};
		MenuPainelAberto = true;
	}


	void SalvarItem()
	{
		int proxID = ItensCenario.Count + 1;
		ItemTemp.Id = proxID;

		ItensCenario.Add(ItemTemp);
		ItemTemp = new();

		ConsumoMes = 0;
		MenuAberto = false;
	}

	void SalvarConsumo()
	{
		ConsumoMes = ConsumoTemp;
		MenuConsumoAberto = false;
	}

	void SalvarPainel()
	{
		PainelDados = PainelTemp;
		PainelTemp = new();
		ConfigPainel = false;
		ConfigPainelFinanceiro = false;
		MenuPainelAberto = false;
	}

	void FecharModal()
	{
		MenuPainelAberto = false;
		ConfigPainel = false;
		ConfigPainelFinanceiro = false;
	}

	void RemoveItem(ItemCenario ItemParaRemover)
	{
		ItensCenario.Remove(ItemParaRemover);

		for (int i = 0; i < ItensCenario.Count; i++)
		{
			ItensCenario[i].Id = i + 1;
		}
	}

	void ResetarCenario()
	{
		ItensCenario.Clear();
		ConsumoMes = 0;
	}

	// Cálculo da quantidade de painéis solares
	public double TempOperacao() => PainelDados.TempAmb + ((PainelDados.Noct - 20.0) / 800.0) * 1000.0;
	public double EficienciaReal() => PainelDados.EficNominal * (1.0 - ((PainelDados.Pmpp / 100.0) * (TempOperacao() - 25.0))); 
	public double GeracaoPorDia() => (PainelDados.Potencia / 1000.0) * (EficienciaReal() / PainelDados.EficNominal) * PainelDados.HorasSol * (PainelDados.Eficiencia / 100);
	public double NumPlacas(double ConsumoDiario) => Math.Round(ConsumoDiario / (GeracaoPorDia()), 4);

	//Cálculo de PayBack

	public double Energia_fv() => GeracaoPorDia() * PlacasCalculadas * 30.0;
	public double Energia_fv_consumida() => (PainelDados.FatorSimA / 100) * Energia_fv();
	public double Energia_injetada() => (1 - (PainelDados.FatorSimA / 100)) * Energia_fv();
	public decimal Tarifa_Plena() => PainelDados.TarifaEnergia + PainelDados.TUSD;
	public decimal Tarifa_energia_injetada() => Tarifa_Plena() - (PainelDados.TUSD * (decimal)PainelDados.ProgressaoFioB);
	public decimal Economia_Mensal() => ((decimal)Energia_fv_consumida() * Tarifa_Plena()) + ((decimal)Energia_injetada() * Tarifa_energia_injetada());
	public int CalculoRetornoMeses(decimal TotalCustoMensal)
	{
		if (TotalCustoMensal <= 0 || Economia_Mensal() <= 0) return 0;
		decimal custoTotalSistema = PainelDados.Custo * PlacasCalculadas;

		return (int)Math.Ceiling(custoTotalSistema / Economia_Mensal());
	}

	public decimal CalculoCusto(ItemCenario item) => Math.Round((decimal)item.CalculoKwh() * (PainelDados.TarifaEnergia + PainelDados.TUSD), 3);
	public decimal TotalCustoItens() => ItensCenario.Sum(item => CalculoCusto(item));

	public string FormatarTempoRetorno(decimal TotalCustoMensal)
	{
		int mesesTotais = CalculoRetornoMeses(TotalCustoMensal);

		if (mesesTotais == 0) return "Imediato";

		int anos = mesesTotais / 12;
		int meses = mesesTotais % 12;

		if (anos > 0 && meses > 0)
			return $"{anos} anos e {meses} meses";

		if (anos > 0)
			return $"{anos} anos";

		return $"{meses} meses";
	}

}